/*
START - Update price level and tax group
*/

//Need to check if there is a gift card item included to check the CBGC-related transaction column
hasGiftCard as bool = false

//Retrieve the tax group associated with the non-taxable setting
if _deptChargeNonTaxable.Equals("T"):
   //Call SQL to retrieve the tax group for the non-taxable setting
   newTaxGroup as duck
   newTaxGroup = NetSuite.Retail.POS.Data.DataCenter.radManager.Scalar("select ID_GP_TX from RAPOS..RU_TX_ATHY where ID_ATHY_TX='"+_deptChargeTaxCode+"' and TS_EP is null")
   
   //Check for a null tax group
   if newTaxGroup == null:
      MC.Alert("Unable to retrieve the tax code for the transaction to be non-taxable. Please use the 'Tax Exempt' standard NSPOS function if this transaction needs to be non-taxable.\n\nAlso, please report this issue to your system administrator.\nThe likely cause of this issue is that the 'Department Charge Non-Taxable Tax Code' setting in the CS Custom Preferences record does not match the non-taxable 'Tax Code/Group' that is set on the Location record corresponding to this NSPOS register.\nPlease review and update these values in NetSuite ERP. The typical tax code/group value that is used for non-taxable transactions is the tax group with internal ID of '-8'.")


//Loop through each item to update tax (if applicable) and price level
lines = MC.GetProperty("Transaction.Item.List")
for x in lines:
   raitem = x as NetSuite.Retail.POS.Shared.RAItem
   giftcarditem = x as NetSuite.Retail.POS.Business.CreditDebitCardTenderLineItem
   if (giftcarditem == null) and (raitem == null):
      print "Not a GiftCard or Regular Item"
      continue
   if (raitem != null) and (raitem.Voided == true):
      print "Voided Item"
      continue
   if giftcarditem != null:
      print "GiftCard item. Don't update price or tax"
      continue
      
   //Mark Gift Card item flag if one exists
   if (giftcarditem != null) and (giftcarditem.Amount != 0):
      hasGiftCard = true
      print "Trx has Gift Card item"
   
   //Set item to tax exempt if flag is true and have a new tax group
   if _deptChargeNonTaxable.Equals("T") and not newTaxGroup == null:
      item = raitem as NetSuite.Retail.POS.Business.SaleReturnLineItem
      item.TaxSwitch(newTaxGroup)
      print "new tax group: "+newTaxGroup

   //TI1553
   //Set Department Charge Price Level via 'setPriceLevel' function
   if not string.IsNullOrEmpty(_deptChargePriceLevel.ToString()) and not _deptChargePriceLevel.Equals("null"):
      
      if raitem.ExtendedProperties.ContainsKey("custitem_ra_item_requireprice") and raitem.ExtendedProperties["custitem_ra_item_requireprice"].Equals("True"):
         if MC.GetYesNo("The item '"+raitem.Name+"' is a Variable Price item that you manually entered the price for. Would you like to update this item's price to be the Department Charge price instead?"):
            print "Setting Dept Charge Price Level"
            setPriceLevel(raitem,_deptChargePriceLevel)
         else:
            continue
      else:      
         print "Setting Dept Charge Price Level"
         setPriceLevel(raitem,_deptChargePriceLevel)
         
MC.Alert("NOTICE: Item prices were updated to the Department Charge price level.")
/*
END - Update price level and tax group
*/ 


/*
START - Dept Charge Credit Limit validation
*/  

//Get transaction total. Used to tender out at end of script and optionally check against DC credit limit if enabled
transTotal as decimal = System.Convert.ToDecimal(MC.GetProperty("Transaction.Total"))

//Check for the Department Charge Transaction Limit being exceeded if the setting is enabled to enforce the limit
if _deptChargeLimitEnforce.ToUpper().Equals("TRUE"):

   //Check the Charge Credit Limit
   ChargeScriptBody as string = '{"validateCreditLimit":[{"purchaseAmount":"'+transTotal+'"}]}'
   print "JSON request for Validate Dept Charge purchase: "+ChargeScriptBody

   //CALL THE DEPARTMENT CHARGE CREDIT LIMIT VALIDATION SCRIPT 
   try:
      ChargeScriptResponse = callValidateSegmentErp(SerializeJson(ChargeScriptBody))
      print "Successful Validate Credit Limit ERP call"
      print "JSON respone for Validate Dept Charge purchase: "+ChargeScriptResponse.response
   except:
      print "Failed Validate Credit Limit ERP call"
      return
      
   /*
   example JSON = "{\"validateCreditLimit\":[{\"purchaseAmount\":7.65,\"creditLimit\":10000,\"limitExceeded\":false,\"errorMsg\":\"\"}]}"
   example JSON after running through 'sanitizeJson' function = {"validateCreditLimit":[{"purchaseAmount":7.65,"creditLimit":10000,"limitExceeded":false,"errorMsg":""}]}
   */

   //Parse JSON response  
   cleanChargeScriptResponse = sanitizeJson(ChargeScriptResponse.response)
   print "Cleaned up JSON response: "+cleanChargeScriptResponse
   _ChargeScriptResponse = DeserializeJson(typeof(ValidateCreditLimitResponse),cleanChargeScriptResponse)

   _purchaseAmount as decimal = _ChargeScriptResponse.validateCreditLimit[0].purchaseAmount
   _creditLimit as string = _ChargeScriptResponse.validateCreditLimit[0].creditLimit
   _limitExceeded as bool = _ChargeScriptResponse.validateCreditLimit[0].limitExceeded
   _errorMsg as string = _ChargeScriptResponse.validateCreditLimit[0].errorMsg

   //Check for the Department Charge Transaction Limit being exceeded and if the setting is enabled to enforce the limit - SVCS776
   if _limitExceeded == true:
      MC.Alert("You have exceeded the Department Charge Transaction Limit of $"+_creditLimit)

      //SVCS7662
      for x in lines:
         raitem = x as NetSuite.Retail.POS.Shared.RAItem
         giftcarditem = x as NetSuite.Retail.POS.Business.CreditDebitCardTenderLineItem
         if (giftcarditem == null) and (raitem == null):
            print "Not a GiftCard or Regular Item"
            continue
         if (raitem != null) and (raitem.Voided == true):
            print "Voided Item"
            continue
         if giftcarditem != null:
            print "GiftCard item. Don't update price or tax"
            continue
         
         //Revert items prices to base price which is "1" in database
         setPriceLevel(raitem,"1")

      MC.Alert("NOTICE: Item prices were reverted to the Base (MSRP) price level.")
      return

/*
END - Dept Charge Credit Limit validation
*/


/*
START - Record comments as needed
*/

//Record transaction body comments for the segments if they are non-null
if not string.IsNullOrEmpty(_seg1D):
   using comment=NetSuite.Retail.POS.Business.Comment("trx"):
      comment.ReasonCode = "CBT1"
      comment.CommentText = _seg1D.Trim()
      comment.Hide=true
      comment.Run()
if not string.IsNullOrEmpty(_seg2ID):
   using comment=NetSuite.Retail.POS.Business.Comment("trx"):
      comment.ReasonCode = "CBT2"
      comment.CommentText = _seg2ID.Trim()
      comment.Hide=true
      comment.Run()

//Mark this as a Dept Charge transaction to check the custbody_nsts_cstr_dept_chg field in ERP
using comment=NetSuite.Retail.POS.Business.Comment("trx"):
   comment.ReasonCode = "CBDC"
   comment.CommentText = "true"
   comment.Hide=true
   comment.Run()   
   
//TI1596 - Record transaction body checkbox if a Gift Certificate item exists on transaction
if hasGiftCard == true:
   print "Gift Certificate comment recorded"
   using comment=NetSuite.Retail.POS.Business.Comment("trx"):
      comment.ReasonCode = "CBGC"
      comment.CommentText = "true"
      comment.Hide=true
      comment.Run()
      
/*PO Customization - MRB*/
if not string.IsNullOrEmpty(_getPONum):
   using comment=NetSuite.Retail.POS.Business.Comment("trx"):
      comment.ReasonCode = "ZZPO"
      comment.CommentText = _getPONum
      comment.Hide=true
      comment.Run()   

//Execute tender
using tenderProcess = NetSuite.Retail.POS.Business.TenderProcess("Tender:DC ${transTotal}"):
   tenderProcess.Run()
   
/*
END - Record comments as needed
*/


//*********
//END
