import System.Runtime.Serialization from System.Runtime.Serialization // import name space containing DataContract and DataMember
import System.Runtime.Serialization.Json from System.Runtime.Serialization // import name space containing DataContractJsonSerializer
   
[DataContract]
public class SearchFilter:
   [DataMember]
   public name as string
   
   [DataMember]
   public operator as string
   
   [DataMember]
   public value as Object
   
[DataContract]
public class SearchRequest:
   [DataMember]
   public searchId as string
   
   [DataMember]
   public filters as (SearchFilter):
      get:
         if filterList == null or filterList.Count == 0:
            return null
         return filterList.ToArray()
      set:
         filterList = System.Collections.Generic.List[ of SearchFilter] ()
         for val in value:
            filterList.Add(val)
   
   public filterList as System.Collections.Generic.List[ of SearchFilter]
 
[DataContract]
public class ValidateCreditLimitResponse:
   [DataMember]
   public validateCreditLimit as System.Collections.Generic.List[ of ValidateCreditLimitJSON]
 
[DataContract]
public class ValidateCreditLimitJSON:
   [DataMember]
   public purchaseAmount as decimal

   [DataMember]
   public creditLimit as string
   
   [DataMember]
   public limitExceeded as bool
   
   [DataMember]
   public errorMsg as string
   
[DataContract]
public class ValidateSegmentResponse:
   [DataMember]
   public validateSegments as System.Collections.Generic.List[ of ValidateSegmentJSON]
   
[DataContract]
public class ValidateSegmentJSON:
   [DataMember]
   public line as string
   
   [DataMember]
   public seg1Text as string
   
   [DataMember]
   public seg1ID as string
   
   [DataMember]
   public seg1Valid as bool
   
   [DataMember]
   public seg2Text as string
   
   [DataMember]
   public seg2ID as string
   
   [DataMember]
   public seg2Valid as bool


/**
 * Deserializes a  JSON string
 *
 * @params
 *   type - The object to serialize
 *   json - json string to deserialize
 * @returns - deserialized JSON
 */

def DeserializeJson(type as System.Type, json as string):
   using dcjs = DataContractJsonSerializer(type):
      bytes as (byte) = System.Text.Encoding.UTF8.GetBytes(json)
      using stream = System.IO.MemoryStream(bytes):
         return dcjs.ReadObject(stream)
   
/**
 * Serializes an object into a JSON string.
 *
 * @params
 *   obj - The object to serialize
 * @returns - JSON string serialization of object
 */
def SerializeJson(obj):
   using dcjs = DataContractJsonSerializer(obj.GetType()):
      using stream = System.IO.MemoryStream():
         dcjs.WriteObject(stream, obj)
         return System.Text.Encoding.UTF8.GetString(stream.ToArray())
   
/**
 * Helper method for getting a value from XmlDocument or XmlNode given a path. Returns a default value if node is not found.
 *
 * @params
 *   node - The XmlDocument or XmlNode parent/root
 *   path - The path to search for single child node
 *   defaultValue - The value to return if child node is not found
 * @returns - InnerText of selected node (or defaultValue if node is not found)
 */
def getNodeInnerText(node, path, defaultValue):
   childNode = node.SelectSingleNode(path)
   if childNode == null:
      return defaultValue
   else:
      return childNode.InnerText
	  
/**
 * Helper method for getting a value from XmlDocument or XmlNode given a path.
 *
 * @params
 *   node - The XmlDocument or XmlNode parent/root
 *   path - The path to search for single child node
 * @returns - InnerText of selected node (or empty string if node is not found)
 */
def getNodeInnerText(node, path):
   return getNodeInnerText(node, path, "")

/**
 * Helper method to clean Xml by replacing invalid characters with escaped versions.
 *
 * @params
 *   dirtyString - The string to clean.
 * @returns - The string with invalid characters replaced with escaped versions.
 */
def sanitizeXml(dirtyString):
   return dirtyString.Replace("&", "&amp;")
   
/**
 * Helper method to clean Json by replacing invalid characters with escaped versions.
 *
 * @params
 *   dirtyString - The string to clean.
 * @returns - The string with invalid characters replaced with escaped versions.
 */
def sanitizeJson(dirtyString):
   return dirtyString.Replace('"','').Replace('\\','"')
   
/**
 * Calls ERP RESTlet for search requests. Tries up to four times to connect.
 *
 * @params
 *   requestBody - Body string to attach to the request, should contain at least the search ID.
 * @returns - Response object if successful (null if error)
 */   
def callErp(requestBody as string):
   // Configure the request object
   request = MC.SendMessage("GetRestletRequest")
   request.method = "POST"
   request.scriptId = "customscript_ra_re_saved_search"
   request.deploymentId = "customdeploy_ra_re_saved_search"
   request.body = requestBody

   MC.SendMessage("Splash.Open")
   MC.SendMessage("StatusUpdate", "Validating Customer is authorized for Dept Charge")

   try:
      for x in range(0,3):
         // Submit the request
         try:
            response = MC.SendMessage("CallRestletOAuth", request)
            if response.success:
               print "Successful Saved Search ERP call"
               response.response = sanitizeXml(response.response)
               return response
            elif x==3:
               MC.Alert("Error retrieving Customer data. \n\nUnable to process Department Charge tender at this time.")
               return null
            else:
               System.Threading.Thread.Sleep(1000)
         except:
            MC.Alert("Error retrieving Customer data. \n\nUnable to process Department Charge tender at this time.")
            return null
   ensure:
      MC.SendMessage("Splash.Close")
   MC.Alert("Error retrieving Customer data. \n\nUnable to process Department Charge tender at this time.")
   return null
   
/**
 * Calls ERP RESTlet for search requests. Tries up to four times to connect.
 *
 * @params
 *   searchRequest - SearchRequest object containing search details
 * @returns - Response object if successful (null if error)
 */
def callErp(searchRequest as SearchRequest):
   return callErp(SerializeJson(searchRequest))
   
/**
 * Calls ERP RESTlet for the NSTS | CSTR | RL | Val Dept Charge Seg script. Tries up to four times to connect.
 *
 * @params
 *   requestBody - Body string to attach to the request, should contain the JSON request to the script.
 * @returns - Response object if successful (null if error)
 */   
def callValidateSegmentErp(requestBody as string):
   // Configure the request object
   request = MC.SendMessage("GetRestletRequest")
   request.method = "POST"
   request.scriptId = "customscript_nsts_cstr_rl_valdepchrgseg"
   request.deploymentId = "customdeploy_nsts_cstr_rl_valdepchrgseg"
   request.body = requestBody
   //request.responseType = typeof(ValidateCreditLimitResponse)

   MC.SendMessage("Splash.Open")
   MC.SendMessage("StatusUpdate", "Validating Dept Charge requirements")

   try:
      for x in range(0,3):
         // Submit the request
         try:
            scriptResponse = MC.SendMessage("CallRestletOAuth", request)
            if scriptResponse.success:
               return scriptResponse
            elif x==3:
               MC.Alert("Error retrieving data. \n\nUnable to validate Department Charge segment at this time.")
               return null
            else:
               System.Threading.Thread.Sleep(1000)
         except:
            MC.Alert("Error retrieving data. \n\nUnable to validate Department Charge segment at this time.")
            return null
   ensure:
      MC.SendMessage("Splash.Close")
   MC.Alert("Error retrieving data. \n\nUnable to validate Department Charge segment at this time.")
   return null
 
/**
 * Sets the an item price level
 *
 * @params
 *    item - the item object
 *    _deptChargePriceLevel - the price level to use
 */      
def setPriceLevel(item as NetSuite.Retail.POS.Business.SaleReturnLineItem, _deptChargePriceLevel as string):
   //Get ID and Price level
   itemID = item.ID_ITM.Trim()
   itemPriceLevel = itemID+"-"+_deptChargePriceLevel+"-USD"
   print "Item price level lookup ID_ITM_SL_PRC is: "+itemPriceLevel
   
   //Call SQL to retrieve price for price level
   newPrice as duck
   newPrice = NetSuite.Retail.POS.Data.DataCenter.radManager.Scalar("select RP_SLS_CRT from RAPOS..RU_ITM_SL_PRC where ID_ITM_SL_PRC = '"+itemPriceLevel+"'")
   
   //Check for a null new price
   if newPrice == null:
      MC.Alert("Item '"+item.Name+"' with Internal ID '"+item.ID_ITM.Trim()+"' does not have a price set for the Department Charge price level.\n\nPlease inform your manager to review the Item record in NetSuite ERP and then re-save the Item record to initiate a sync to NSPOS. This item will be tendered using the base price level assigned at this location (typically MSRP).")
      return

   //Update the item's price
   item.Changing()
   item.ActualUnitPrice = item.RegularUnitPrice = newPrice
   item.Update()
   item.ApplyChanges()
   
   



