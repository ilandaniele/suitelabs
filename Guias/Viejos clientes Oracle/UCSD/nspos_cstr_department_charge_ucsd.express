   //Create the JSON for the Department Charge Accounting Segment(s) to ERP validation script. line is hardcoded as "1" since we only validate one set of segments
   SegmentScriptBody as string = '{"validateSegments":[{"line":"1","seg1Text":"'+segment1+'","seg2Text":"'+segment2+'"}]}'
      
   //Call the Deparment Charge Validation Script 
   try:
      SegmentScriptResponse = callValidateSegmentErp(SerializeJson(SegmentScriptBody))
      print "Successful Validate Segment ERP call"
      print SegmentScriptResponse.response
   except:
      print "Failed Validate Segment ERP call"
      return

    /*
   Example JSON response: "{\"validateSegments\":[{\"line\":\"1\",\"seg1Text\":\"d1\",\"seg1ID\":\"\",\"seg1Valid\":false,\"seg2Text\":\"d2\",\"seg2ID\":\"\",\"seg2Valid\":false}]}"
   Cleaned up Segment JSON response: {"validateSegments":[{"line":"1","seg1Text":"d1","seg1ID":"","seg1Valid":false,"seg2Text":"d2","seg2ID":"","seg2Valid":false}]}
   */

   //Cleanup JSON response 
   cleanSegmentScriptResponse = sanitizeJson(SegmentScriptResponse.response)
   print "Cleaned up Segment JSON response: "+cleanSegmentScriptResponse
   _SegmentScriptResponse = DeserializeJson(typeof(ValidateSegmentResponse),cleanSegmentScriptResponse)


   //Parse the JSON response to determine if segments were valid
   _line as string
   _seg1Text as string
   _seg1D as string
   _seg1Valid as bool
   _seg2Text as string
   _seg2ID as string
   _seg2Valid as bool

   _line = _SegmentScriptResponse.validateSegments[0].line
   print "line: "+_line
   _seg1Text = _SegmentScriptResponse.validateSegments[0].seg1Text
   print "seg1Text: "+_seg1Text
   _seg1D = _SegmentScriptResponse.validateSegments[0].seg1ID
   print "seg1ID: "+_seg1D
   _seg1Valid = _SegmentScriptResponse.validateSegments[0].seg1Valid
   print "seg1Valid: "+_seg1Valid
   _seg2Text = _SegmentScriptResponse.validateSegments[0].seg2Text
   print "seg2Text: "+_seg2Text
   _seg2ID = _SegmentScriptResponse.validateSegments[0].seg2ID
   print "seg2ID: "+_seg2ID
   _seg2Valid = _SegmentScriptResponse.validateSegments[0].seg2Valid
   print "seg2Valid: "+_seg2Valid

   if _seg1Valid == false:
      MC.Alert("The first Accounting Segment '${_seg1Text}' is not valid. Please doublecheck your Accounting Segments and retry.")
      return
      
   if _seg2Valid == false:
      MC.Alert("The second Accounting Segment '${_seg2Text}' is not valid. Please doublecheck your Accounting Segments and retry.")
      return

/*
END - Dept Charge Accounting Segment validation
