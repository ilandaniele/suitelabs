        },
        "application": {
            "shopping": {
                "files": [
                    "Modules/Main/JavaScript/NSeComm.CookieModalConfirmation.Main.js",
                    "Modules/CookieModalConfirmation/JavaScript/CookieModalConfirmation.View.js"
                ]
            }
        }
    },
    "local_folder": "Workspace/CookieModalConfirmation"
