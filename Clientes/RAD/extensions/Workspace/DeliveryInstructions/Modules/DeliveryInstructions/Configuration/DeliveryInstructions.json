      "group": "checkoutApp",
      "subtab": "deliveryinstructions",
      "type": "string",
      "title": "White Glove Title",
      "default": "White Glove"
    },
    "deliveryinstructions.whiteGlove.message": {
      "group": "checkoutApp",
      "subtab": "deliveryinstructions",
      "type": "string",
      "nsType": "textarea",
      "title": "White Glove Message",
      "default": "Delivery includes in-room placement of item(s), packaging removal, and up to 1 flight of stair carry"
    },
    "deliveryinstructions.whiteGlove.modalTitle": {
      "group": "checkoutApp",
      "subtab": "deliveryinstructions",
      "type": "string",
      "title": "White Glove Modal Title",
      "default": "White Glove Delivery"
    },
    "deliveryinstructions.whiteGlove.disclaimer": {
      "group": "checkoutApp",
      "subtab": "deliveryinstructions",
      "type": "string",
      "nsType": "textarea",
      "title": "White Glove Modal Disclaimer",
      "default": "Do you agree with disabling the White Glove delivery service?"
    }
  }
}
