<ul class="social">
    {{#if instagramUrl}}
        <li class="social-item"><a href="{{instagramUrl}}" class="instagram-footer-icon" aria-label="Instagram"></a></li>
    {{/if}}
    {{#if facebookUrl}}
        <li class="social-item"><a href="{{facebookUrl}}" class="facebook-footer-icon" aria-label="Facebook"></a></li>
    {{/if}}
    {{#if pinterestUrl}}
        <li class="social-item"><a href="{{pinterestUrl}}" class="pinterest-footer-icon" aria-label="Pinterest"></a></li>
    {{/if}}
    {{#if linkedinUrl}}
        <li class="social-item"><a href="{{linkedinUrl}}" class="linkedin-footer-icon" aria-label="LinkedIn"></a></li>
    {{/if}}
    {{#if youtubeUrl}}
        <li class="social-item"><a href="{{youtubeUrl}}" class="youtube-footer-icon" aria-label="YouTube"></a></li>
    {{/if}}
    {{#if googleUrl}}
        <li class="social-item"><a href="{{googleUrl}}" class="googlePlus-footer-icon" aria-label="Google"></a></li>
    {{/if}}
    {{#if twitterUrl}}
        <li class="social-item"><a href="{{twitterUrl}}" class="twitter-footer-icon" aria-label="Twitter"></a></li>
    {{/if}}
</ul>
