<div class="store-locator-main">
	<div class="store-locator-main-title">
		<h1>Primary Arms Optics Dealer Locator</h1>
	</div>
	<div class="store-locator-main-layout">
		<div class="store-locator-main-container">
			<div class="store-locator-main-links">
				<a href="/all-optics/red-dot-sights/brand/primary-arms">
					<img class="img-size" src="{{getThemeAssetsPath 'img/Red-Dots.jpg'}}" alt="Red dots"/>
					<p class="store-locator-main-description">Shop Red Dots</p>
				</a>
			</div>
			<div class="store-locator-main-links">
				<a href="/all-optics/rifle-scopes/brand/primary-arms">
					<img class="img-size" src="{{getThemeAssetsPath 'img/Rifle-Scopes.jpg'}}" alt="Rifle scopes"/>
					<p class="store-locator-main-description">Shop Rifle Scopes</p>
				</a>
			</div>
			<div class="store-locator-main-links">
				<a href="/all-optics/red-dot-sights/mini-reflex-sights/brand/primary-arms">
					<img class="img-size" src="{{getThemeAssetsPath 'img/Reflex.jpg'}}" alt="Reflex dots"/>
					<p class="store-locator-main-description">Shop Reflex Sights</p>
				</a>
			</div>
		</div>
		<div class="store-locator-main-layout-left">
			<div class="store-locator-main-search" data-view="StoreLocatorSearch"></div>
			<div class="store-locator-main-results" data-view="StoreLocatorResults"></div>
			<!--
				<div class="store-locator-main-see-all-stores">
					<a data-hashtag="stores/all" href="stores/all">{{translate 'See complete list of stores'}}</a>
				</div>
			-->
		</div>
		<div class="store-locator-main-layout-right">
			<div class="store-locator-main-map" data-view="StoreLocatorMap" data-type="map-view"></div>
		</div>
	</div>
</div>



