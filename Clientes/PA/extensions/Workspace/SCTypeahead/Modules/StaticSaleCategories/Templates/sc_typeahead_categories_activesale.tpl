<div class="panel sctypahead-category" style='background-image: url("{{categoryBackgroundUrl}}");' >
  <div class="panel-body">
    <h5 class="panel-title"> {{{categoryLabel}}}</h5>
    {{#if categoryDescription}}
      <p class="card-text">categoryDescription</p>
    {{/if}}    
  </div>

  <div class="panel-footer">
    <div class="buttons-set" style="margin-top: 15px;">
      <a href="{{categoryRedirectUrl}}" data-hashtag="{{categoryRedirectUrl}}" data-touchpoint="home" class="btn btn-primary">Shop Now</a>
    </div>
  </div>
</div> 