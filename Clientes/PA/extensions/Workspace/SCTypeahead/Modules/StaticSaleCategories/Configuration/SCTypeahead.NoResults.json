{
	"type": "object",
    "subtab": {
        "id": "noresults",
        "title": "No-Results",
        "description": "Manage No-Result Appearance",
        "group": "sctypeahead"
    }
,	"properties": {
        "sctypeahead.noresults.message":{
            "type": "string",
            "nsType": "textarea",
            "translate": true,
            "default": "Sorry, we were unable to find results for $(0). Please check your spelling or try searching for similar terms. You can also take a look at our current sale/promotions below.",
            "title": "No Result Message",
            "description": "Message to be shown when no products for search query",
            "subtab": "noresults",
            "group": "sctypeahead"
        },

        "sctypeahead.noresults.allowStaticCategoriesWhenNoResult":{
            "type": "boolean",
            "default": false,
            "title": "Allow Static categories to be shown when no result found",
            "description": "Enabling this will show static categories when no results are being shown for keyword.",
            "subtab": "noresults",
            "group": "sctypeahead"
        },

        "sctypeahead.noresults.staticCategories":{
            "group": "sctypeahead",
            "type": "array",
            "subtab": "noresults",
            "title": "Categories to be shown when No Results",
            "description": "Categories to be shown when search criteria did not return any results",
            "items": {
                "type": "object",
                "properties" : {
                    "categoryBackgroundUrl": {
                        "type": "string",
                        "title": "Background Image Url",
                        "description": "Category Background Image Url",
                        "mandatory": false
                    },
                    "categoryLabel": {
                        "type": "string",
                        "title": "Caption",
                        "nsType": "textarea",
                        "description": "Category Label",
                        "mandatory": true
                    },
                    "categoryDescription": {
                        "type": "string",
                        "title": "Description",
                        "nsType": "textarea",
                        "description": "Category Description",
                        "mandatory": false
                    },
                    "categoryRedirectUrl": {
                        "type": "string",
                        "title": "Redirect Url",
                        "description": "Category Redirect Url",
                        "mandatory": true
                    }
                }
            }
        }
	}
}